{
  "datasets": [
    {
      "name": "ds_test",
      "displayName": "Test",
      "queryLines": [
        "SELECT 'A' as cat, 10 as val, 'tooltip text' as info"
      ]
    }
  ],
  "pages": [
    {
      "name": "test",
      "displayName": "Tooltip Test",
      "layout": [
        {
          "widget": {
            "name": "bar_with_tooltip",
            "queries": [
              {
                "name": "main_query",
                "query": {
                  "datasetName": "ds_test",
                  "fields": [
                    {
                      "name": "sum(val)",
                      "expression": "SUM(`val`)"
                    },
                    {
                      "name": "cat",
                      "expression": "`cat`"
                    },
                    {
                      "name": "info",
                      "expression": "`info`"
                    },
                    {
                      "name": "val",
                      "expression": "`val`"
                    }
                  ],
                  "disaggregated": false
                }
              }
            ],
            "spec": {
              "version": 3,
              "frame": {
                "showTitle": true,
                "title": "Bar with Tooltip"
              },
              "widgetType": "bar",
              "encodings": {
                "x": {
                  "fieldName": "val",
                  "displayName": "Value",
                  "scale": {
                    "type": "quantitative"
                  }
                },
                "y": {
                  "fieldName": "cat",
                  "displayName": "Category",
                  "scale": {
                    "type": "categorical"
                  }
                },
                "extra": [
                  {
                    "fieldName": "sum(val)"
                  },
                  {
                    "fieldName": "cat"
                  },
                  {
                    "fieldName": "info"
                  }
                ]
              }
            }
          },
          "position": {
            "x": 0,
            "y": 0,
            "width": 6,
            "height": 5
          }
        }
      ],
      "pageType": "PAGE_TYPE_CANVAS",
      "layoutVersion": "GRID_V1"
    }
  ],
  "uiSettings": {
    "theme": {
      "widgetHeaderAlignment": "ALIGNMENT_UNSPECIFIED"
    },
    "applyModeEnabled": false
  }
}
