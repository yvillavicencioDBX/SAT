{
  "datasets": [
    {
      "name": "ds_recaudacion_mensual",
      "displayName": "Recaudación Mensual",
      "queryLines": [
        "SELECT\n",
        "  fecha,\n",
        "  anio,\n",
        "  nombre_mes,\n",
        "  isr_total,\n",
        "  iva_total,\n",
        "  ieps_total,\n",
        "  otros_impuestos,\n",
        "  total_tributario,\n",
        "  meta_lif,\n",
        "  cumplimiento_pct\n",
        "FROM sat_demo.recaudacion_mensual\n",
        "ORDER BY fecha"
      ]
    },
    {
      "name": "ds_recaudacion_anual",
      "displayName": "Recaudación Anual por Impuesto",
      "queryLines": [
        "SELECT\n",
        "  anio,\n",
        "  SUM(isr_total)        AS isr_total,\n",
        "  SUM(iva_total)        AS iva_total,\n",
        "  SUM(ieps_total)       AS ieps_total,\n",
        "  SUM(otros_impuestos)  AS otros_impuestos,\n",
        "  SUM(total_tributario) AS total_tributario,\n",
        "  AVG(cumplimiento_pct) AS cumplimiento_pct\n",
        "FROM sat_demo.recaudacion_mensual\n",
        "GROUP BY anio\n",
        "ORDER BY anio"
      ]
    },
    {
      "name": "ds_contribuyentes",
      "displayName": "Contribuyentes por Régimen",
      "queryLines": [
        "SELECT\n",
        "  anio,\n",
        "  regimen,\n",
        "  tipo_persona,\n",
        "  sector_economico,\n",
        "  total_registrados,\n",
        "  total_activos,\n",
        "  nuevos_registros,\n",
        "  bajas\n",
        "FROM sat_demo.contribuyentes_padron\n",
        "ORDER BY anio, total_activos DESC"
      ]
    },
    {
      "name": "ds_total_contribuyentes",
      "displayName": "Total Contribuyentes",
      "queryLines": [
        "SELECT\n",
        "  SUM(total_registrados) AS total_registrados,\n",
        "  SUM(total_activos)     AS total_activos\n",
        "FROM sat_demo.contribuyentes_padron\n",
        "WHERE anio = 2024"
      ]
    },
    {
      "name": "ds_declaraciones",
      "displayName": "Declaraciones por Tipo",
      "queryLines": [
        "SELECT\n",
        "  fecha,\n",
        "  tipo_declaracion,\n",
        "  subtipo,\n",
        "  SUM(presentadas)           AS presentadas,\n",
        "  SUM(con_pago)              AS con_pago,\n",
        "  SUM(en_ceros)              AS en_ceros,\n",
        "  SUM(a_favor_contribuyente) AS a_favor,\n",
        "  SUM(extemporaneas)         AS extemporaneas\n",
        "FROM sat_demo.declaraciones\n",
        "WHERE anio = 2024\n",
        "GROUP BY fecha, tipo_declaracion, subtipo\n",
        "ORDER BY fecha"
      ]
    },
    {
      "name": "ds_retenciones",
      "displayName": "Retenciones ISR por Sector",
      "queryLines": [
        "SELECT\n",
        "  fecha,\n",
        "  sector_economico,\n",
        "  concepto,\n",
        "  SUM(monto_retenido)   AS monto_total,\n",
        "  SUM(num_empleadores)  AS empleadores,\n",
        "  SUM(num_trabajadores) AS trabajadores\n",
        "FROM sat_demo.retenciones_detalle\n",
        "GROUP BY fecha, sector_economico, concepto\n",
        "ORDER BY fecha, monto_total DESC"
      ]
    },
    {
      "name": "ds_devoluciones",
      "displayName": "Devoluciones y Compensaciones",
      "queryLines": [
        "SELECT\n",
        "  fecha,\n",
        "  impuesto,\n",
        "  tipo_operacion,\n",
        "  sector_economico,\n",
        "  SUM(monto)              AS monto_total,\n",
        "  SUM(num_solicitudes)    AS solicitudes,\n",
        "  AVG(dias_prom_atencion) AS dias_promedio\n",
        "FROM sat_demo.devoluciones_compensaciones\n",
        "GROUP BY fecha, impuesto, tipo_operacion, sector_economico\n",
        "ORDER BY fecha"
      ]
    },
    {
      "name": "ds_fiscalizacion",
      "displayName": "Fiscalización por Tipo de Acto",
      "queryLines": [
        "SELECT\n",
        "  fecha,\n",
        "  tipo_acto,\n",
        "  sector_contribuyente,\n",
        "  SUM(actos_realizados)   AS actos,\n",
        "  SUM(recaudacion_mdp)    AS recaudacion,\n",
        "  AVG(rentabilidad)       AS rentabilidad,\n",
        "  AVG(efectividad_pct)    AS efectividad\n",
        "FROM sat_demo.fiscalizacion\n",
        "WHERE anio = 2024\n",
        "GROUP BY fecha, tipo_acto, sector_contribuyente\n",
        "ORDER BY fecha"
      ]
    }
  ],
  "pages": [
