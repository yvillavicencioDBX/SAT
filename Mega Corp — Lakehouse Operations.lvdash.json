{
  "datasets": [
    {
      "name": "ds_kpi",
      "displayName": "KPI summary",
      "query": "SELECT COUNT(DISTINCT order_id) AS total_orders, ROUND(SUM(total_amount), 0) AS total_revenue, ROUND(AVG(total_amount), 2) AS avg_order_value, COUNT(DISTINCT customer_id) AS active_customers, ROUND(SUM(total_amount) / COUNT(DISTINCT customer_id), 2) AS revenue_per_customer FROM megacorp.silver.orders WHERE _is_valid = true AND status = 'completed'"
    },
    {
      "name": "ds_rev_qtr",
      "displayName": "Revenue quarterly",
      "query": "SELECT CONCAT(order_year, '-Q', order_quarter) AS quarter, region, SUM(total_revenue) AS revenue, SUM(order_count) AS orders FROM megacorp.gold.revenue_monthly GROUP BY order_year, order_quarter, region ORDER BY quarter"
    },
    {
      "name": "ds_rev_region",
      "displayName": "Revenue by region",
      "query": "SELECT region, ROUND(SUM(total_revenue), 0) AS total_revenue, SUM(order_count) AS total_orders, SUM(unique_customers) AS unique_customers FROM megacorp.gold.revenue_monthly GROUP BY region ORDER BY total_revenue DESC"
    },
    {
      "name": "ds_top_prod",
      "displayName": "Top 15 products",
      "query": "SELECT product_name, category, ROUND(total_revenue, 0) AS total_revenue, total_units_sold, ROUND(margin_pct, 1) AS margin_pct, revenue_rank FROM megacorp.gold.product_performance WHERE revenue_rank <= 15 ORDER BY revenue_rank"
    },
    {
      "name": "ds_clv",
      "displayName": "Customer segments",
      "query": "SELECT clv_segment, COUNT(*) AS customer_count, ROUND(AVG(lifetime_revenue), 0) AS avg_lifetime_revenue, ROUND(AVG(total_orders), 1) AS avg_orders FROM megacorp.gold.customer_lifetime_value GROUP BY clv_segment ORDER BY avg_lifetime_revenue DESC"
    },
    {
      "name": "ds_eq_summary",
      "displayName": "Equipment status",
      "query": "SELECT health_status, COUNT(DISTINCT equipment_id) AS equipment_count, ROUND(AVG(anomaly_rate), 2) AS avg_anomaly_rate FROM megacorp.gold.equipment_health_daily WHERE reading_date >= DATEADD(DAY, -7, CURRENT_DATE()) GROUP BY health_status"
    },
    {
      "name": "ds_eq_critical",
      "displayName": "Critical equipment",
      "query": "SELECT equipment_id, location, COUNT(*) AS critical_days, ROUND(AVG(anomaly_rate), 2) AS avg_anomaly_rate, MAX(reading_date) AS last_critical FROM megacorp.gold.equipment_health_daily WHERE health_status = 'CRITICAL' GROUP BY equipment_id, location ORDER BY critical_days DESC LIMIT 15"
    },
    {
      "name": "ds_eq_trend",
      "displayName": "Anomaly trend",
      "query": "SELECT reading_date, health_status, COUNT(DISTINCT equipment_id) AS equipment_count FROM megacorp.gold.equipment_health_daily WHERE reading_date >= DATEADD(DAY, -30, CURRENT_DATE()) GROUP BY reading_date, health_status ORDER BY reading_date"
    },
    {
      "name": "ds_funnel_dev",
      "displayName": "Funnel by device",
      "query": "SELECT device, SUM(total_sessions) AS sessions, SUM(product_views) AS product_views, SUM(cart_sessions) AS cart_sessions, SUM(purchase_sessions) AS purchases, ROUND(SUM(purchase_sessions) / SUM(total_sessions) * 100, 2) AS conversion_rate FROM megacorp.gold.conversion_funnel_daily GROUP BY device ORDER BY sessions DESC"
    },
    {
      "name": "ds_funnel_daily",
      "displayName": "Daily conversion",
      "query": "SELECT event_date, SUM(total_sessions) AS sessions, SUM(purchase_sessions) AS purchases, ROUND(SUM(purchase_sessions) / SUM(total_sessions) * 100, 2) AS conversion_rate FROM megacorp.gold.conversion_funnel_daily GROUP BY event_date ORDER BY event_date"
    },
    {
      "name": "ds_funnel_country",
      "displayName": "Conversion by country",
      "query": "SELECT country, SUM(total_sessions) AS sessions, SUM(purchase_sessions) AS purchases, ROUND(SUM(purchase_sessions) / SUM(total_sessions) * 100, 2) AS conversion_rate FROM megacorp.gold.conversion_funnel_daily GROUP BY country ORDER BY sessions DESC LIMIT 10"
    },
    {
      "name": "ds_inventory",
      "displayName": "Inventory alerts",
      "query": "SELECT p.product_name, p.category, p.stock_quantity, p.reorder_point, p.warehouse, COALESCE(pp.total_revenue, 0) AS total_revenue, CASE WHEN p.stock_quantity = 0 THEN 'OUT OF STOCK' WHEN p.stock_quantity < p.reorder_point * 0.5 THEN 'CRITICAL' ELSE 'LOW' END AS urgency FROM megacorp.silver.products p LEFT JOIN megacorp.gold.product_performance pp ON p.product_id = pp.product_id WHERE p.needs_reorder = true AND p.status = 'active' ORDER BY total_revenue DESC LIMIT 20"
    },
    {
      "name": "ds_freshness",
      "displayName": "Data freshness",
      "query": "SELECT 'Bronze - Orders' AS layer, MAX(_ingested_at) AS last_refresh FROM megacorp.bronze.raw_orders UNION ALL SELECT 'Bronze - Sensors', MAX(_ingested_at) FROM megacorp.bronze.raw_sensor_readings UNION ALL SELECT 'Silver - Orders', MAX(_silver_processed_at) FROM megacorp.silver.orders UNION ALL SELECT 'Gold - Revenue', MAX(_gold_processed_at) FROM megacorp.gold.revenue_monthly UNION ALL SELECT 'Gold - Equipment', MAX(_gold_processed_at) FROM megacorp.gold.equipment_health_daily ORDER BY last_refresh DESC"
    }
  ],
